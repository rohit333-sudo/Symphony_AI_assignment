        {
          "name": "Get Member Borrow Records",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/members/{{memberId}}/borrows",
              "host": ["{{baseUrl}}"],
              "path": ["api", "members", "{{memberId}}", "borrows"]
            },
            "description": "Get all borrow records for a specific member"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Borrows",
      "item": [
        {
          "name": "Borrow Book",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bookId\": 1,\n  \"memberId\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/borrows",
              "host": ["{{baseUrl}}"],
              "path": ["api", "borrows"]
            },
            "description": "Create a borrow record for a book"
          },
          "response": []
        },
        {
          "name": "Return Book",
          "request": {
            "method": "PUT",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/borrows/{{borrowId}}/return",
              "host": ["{{baseUrl}}"],
              "path": ["api", "borrows", "{{borrowId}}", "return"]
            },
            "description": "Mark a borrowed book as returned"
          },
          "response": []
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "authorId",
      "value": "1",
      "type": "string"
    },
    {
      "key": "bookId",
      "value": "1",
      "type": "string"
    },
    {
      "key": "memberId",
      "value": "1",
      "type": "string"
    },
    {
      "key": "borrowId",
      "value": "1",
      "type": "string"
    }
  ]
}
